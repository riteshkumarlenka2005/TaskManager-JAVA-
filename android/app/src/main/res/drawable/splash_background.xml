<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Dark navy background with subtle gradient -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#131321"
                android:centerColor="#131321"
                android:endColor="#0A0F14"
                android:type="linear"
                android:angle="270" />
        </shape>
    </item>

    <!-- Subtle teal glow at top -->
    <item
        android:top="-200dp"
        android:left="-100dp"
        android:right="-100dp">
        <shape android:shape="oval">
            <gradient
                android:startColor="#1A46F0D2"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="400dp" />
            <size
                android:width="600dp"
                android:height="400dp" />
        </shape>
    </item>
</layer-list>
